# MongoDB Atlas connection string (Database > Connect > Drivers).
# Include the database name, e.g. .../drug_results?retryWrites=true&w=majority
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/drug_results?retryWrites=true&w=majority"

# Secret used to sign session JWTs. Use a long random string.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="change-this-to-a-long-random-secret"

# First SuperAdmin, created by `npm run seed`
SUPERADMIN_NAME="Super Admin"
SUPERADMIN_EMAIL="super@admin.test"
SUPERADMIN_PASSWORD="password"
SUPERADMIN_NATIONAL_ID="SUPER-0001"
